<!DOCTYPE html>
<html>
<head>
    <title>System Boot 💻</title>

    <style>
        body {
            margin: 0;
            background: radial-gradient(circle at top, #0b1b2b, #050914, #000000);
            color: #8fd3ff;
            font-family: monospace;
            overflow: hidden;
        }

        /* terminal */
        #terminal {
            padding: 30px;
            font-size: 18px;
            white-space: pre-line;
        }

        /* cursor */
        .cursor::after {
            content: "_";
            animation: blink 0.8s infinite;
        }

        @keyframes blink {
            50% { opacity: 0; }
        }

        /* button */
        .btn {
            display: none;
            margin-top: 20px;
            padding: 10px 20px;
            background: transparent;
            border: 1px solid #8fd3ff;
            color: #8fd3ff;
            cursor: pointer;
        }

        .btn:hover {
            background: #8fd3ff;
            color: black;
        }

        .center {
            text-align: center;
        }

        #story {
            display: none;
            padding: 40px;
            text-align: center;
        }

        h1 {
            color: #8fd3ff;
            text-shadow: 0 0 10px #8fd3ff;
        }

        /* floating hearts */
        .heart {
            position: absolute;
            bottom: -20px;
            color: #66ccff;
            font-size: 16px;
            animation: floatUp linear infinite;
            opacity: 0.8;
        }

        @keyframes floatUp {
            0% { transform: translateY(0) scale(1); opacity: 0; }
            30% { opacity: 1; }
            100% { transform: translateY(-100vh) scale(1.3); opacity: 0; }
        }

        /* music hidden */
        audio {
            display: none;
        }
    </style>
</head>

<body>

<!-- MUSIC 🎵 -->
<audio autoplay loop>
    <source src="https://cdn.pixabay.com/download/audio/2022/10/25/audio_5c3a1f6f2c.mp3?filename=soft-piano-ambient-121257.mp3" type="audio/mpeg">
</audio>

<div id="terminal" class="cursor"></div>

<div class="center">
    <button class="btn" id="btn" onclick="startStory()">ENTER MEMORY CORE ⚡</button>
</div>

<div id="story">
    <h1>I use Arch... btw 💙</h1>
    <p id="text"></p>

    <button class="btn" onclick="finalWish()">Decrypt Final Message 🔐</button>

    <p id="final"></p>
</div>

<script>
let terminal = document.getElementById("terminal");

let lines = [
"Booting Arch Linux...",
"Loading kernel...",
"Establishing secure connection...",
"[ OK ] System stable",
"",
"user@arch:~$ neofetch",
"OS: Arch Linux",
"User: Legendary Human 💙",
"",
"user@arch:~$ pacman -S memories",
"> installing: gaming_sessions",
"> installing: late_night_talks",
"> installing: random_laughter",
"> done ✔",
"",
"user@arch:~$ cat feelings.txt",
"> You didn’t just become a friend...",
"> you became part of my system 💙",
"",
"user@arch:~$ sudo give_hug",
"> permission granted 🤝"
];

let i = 0;

function type() {
    if (i < lines.length) {
        terminal.innerHTML += lines[i] + "\n";
        i++;
        setTimeout(type, 700);
    } else {
        document.getElementById("btn").style.display = "inline-block";
    }
}

type();

/* hearts */
function createHeart() {
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "💙";

    heart.style.left = Math.random() * 100 + "vw";
    heart.style.animationDuration = (Math.random() * 4 + 3) + "s";
    heart.style.fontSize = (Math.random() * 10 + 10) + "px";

    document.body.appendChild(heart);

    setTimeout(() => {
        heart.remove();
    }, 7000);
}

setInterval(createHeart, 400);

function startStory() {
    document.getElementById("terminal").style.display = "none";
    document.getElementById("btn").style.display = "none";
    document.getElementById("story").style.display = "block";

    let msg = "From system commands...\nTo real conversations...\nYou became something I didn’t expect...\nBut now I don’t want to lose 💙";

    let index = 0;

    function typing() {
        if (index < msg.length) {
            document.getElementById("text").innerHTML += msg.charAt(index);
            index++;
            setTimeout(typing, 40);
        }
    }

    typing();
}

function finalWish() {
    document.getElementById("final").innerHTML =
`
Happy Birthday 💙

I don’t really know how to say everything perfectly,
but I’m really grateful you exist in my life.

May Allah always keep you happy, healthy, and successful.
May every difficulty become easy for you.

Thank you for being you...
Have a really good day today 💙
`;
}
</script>

</body>
</html>
